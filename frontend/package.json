{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/gen-version.js",
    "build": "npm run version && npm run sw && vite build && node scripts/compress-assets.js dist",
    "preview": "vite preview",
    "test": "vitest run",
    "pretest": "node scripts/gen-version.js",
    "test:watch": "vitest",
    "lint": "eslint src shared",
    "lint:fix": "eslint src shared --fix",
    "format": "prettier --check src shared",
    "format:fix": "prettier --write src shared",
    "version": "node scripts/gen-version.js",
    "sw": "node scripts/gen-sw.js",
    "compress": "node scripts/compress-assets.js dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
