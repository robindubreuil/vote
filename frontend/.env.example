# URL WebSocket (en dev, le proxy Vite forward vers le backend)
VITE_WS_URL=ws://localhost:8080/ws

# URL de base du frontend stagiaire (pour la fonction "Aide à la connexion").
# Si défini, le QR code et le lien manuel pointeront vers cette URL suivie
# du code session en hash (ex: https://vote.example.com/#1234).
#
# En l'absence de cette variable, l'URL est dérivée du chemin du formateur
# (formateur sur /formateur/ -> stagiaire sur /stagiaire/), ce qui couvre le
# cas de dev et la plupart des déploiements symétriques.
#
# Pour un déploiement où le stagiaire est servi à la racine d'un sous-domaine
# tandis que le formateur est sous /formateur/, fixer cette variable:
# VITE_STAGIAIRE_BASE_URL=https://vote.example.com/
