#!/bin/bash
set -e

case "$1" in
    configure)
        # Create vote user and group if they don't exist
        if ! getent passwd vote > /dev/null 2>&1; then
            adduser --system --group --home /var/lib/vote \
                --gecos "Vote Coloré server" --shell /usr/sbin/nologin \
                vote || true
        fi

        # Create and set permissions for runtime directories
        install -d -o vote -g vote -m 0755 /var/lib/vote
        install -d -o vote -g vote -m 0755 /var/log/vote

        # Enable the service but don't start it (admin will start it)
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || true
            systemctl enable vote.service || true
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	# The following line should be removed in trixie or trixie+1
	deb-systemd-helper unmask 'vote.service' >/dev/null || true

	# was-enabled defaults to true, so new installations run enable.
	if deb-systemd-helper --quiet was-enabled 'vote.service'; then
		# Enables the unit on first installation, creates new
		# symlinks on upgrades if the unit file has changed.
		deb-systemd-helper enable 'vote.service' >/dev/null || true
	else
		# Update the statefile to add new symlinks (if any), which need to be
		# cleaned up on purge. Also remove old symlinks.
		deb-systemd-helper update-state 'vote.service' >/dev/null || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -d /run/systemd/system ]; then
		systemctl --system daemon-reload >/dev/null || true
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		deb-systemd-invoke $_dh_action 'vote.service' >/dev/null || true
	fi
fi
# End automatically added section


exit 0
