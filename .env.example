# Port du serveur (défaut: 8080)
PORT=8080

# Origines CORS autorisées (séparées par virgules)
# En production, restreindre aux origines de vos frontends
# Exemple: https://mondomaine.com,https://formateur.mondomaine.com
# Note: * autorise toutes les origines mais désactive les credentials
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Proxies de confiance (séparés par virgules)
# Requis si derrière un reverse proxy (nginx) pour la détection d'IP
# TRUSTED_PROXIES=127.0.0.1

# Couleurs valides (séparées par virgule)
# VALID_COLORS=rouge,vert,bleu,jaune,orange,violet,rose,gris

# Tableau de bord responsable (/dashboard)
# Non défini = dashboard désactivé (404 sur toutes les routes /dashboard*)
# Définir à une chaîne aléatoire (ex: openssl rand -base64 32) pour activer
# VOTE_DASHBOARD_SECRET=

# Durée de validité du cookie de connexion au dashboard (défaut: 168h = 7 jours)
# VOTE_DASHBOARD_MAX_AGE=168h

# Répertoire de persistance des compteurs (FHS: /var/lib/vote en prod)
# Contient counters.json (point de restauration) + stats.jsonl (historique)
# Défaut: ./data (dev). Le Dockerfile utilise /var/lib/vote (volume déclaré)
# VOTE_DATA_DIR=./data

# Intervalle d'échantillonnage des compteurs vers le disque (défaut: 5m)
# VOTE_STATS_INTERVAL=5m

# URL WebSocket (optionnel, pour les frontends en dev)
# VITE_WS_URL=ws://localhost:8080/ws
